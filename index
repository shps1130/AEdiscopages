}
async function answerQ(id){
  const ta = $('ans-'+id);
  const answer = ta.value.trim();
  if(!answer) return;
  try{
    const r = await api('/api/questions', {action:'answer', questionId:id, answer});
    toast(r.notified ? 'Answered — notification sent' : 'Answered (no recipient set for this page)');
    loadInbox();
  }catch(e){ toast('Failed: '+e.message); }
}

/* ---------- auth ---------- */
function gateMode(mode){
  $('gate-login').style.display = mode==='login' ? 'block' : 'none';
  $('gate-signup').style.display = mode==='signup' ? 'block' : 'none';
  $('gate-title').textContent = mode==='login' ? 'Sign in' : 'Create account';
  $('gate-err').style.display='none';
}
function gateErr(msg){ $('gate-err').textContent = msg; $('gate-err').style.display='block'; }

async function initAuth(){
  try{
    const cfg = await api('/api/auth', {action:'config'});
    SB = window.supabase.createClient(cfg.supabaseUrl, cfg.supabaseAnonKey);
    const { data } = await SB.auth.getSession();
    if (data?.session){ SESSION = data.session; await enter(); }
    SB.auth.onAuthStateChange((_e, session)=>{ SESSION = session; });
  }catch(e){ gateErr('Could not reach the server: '+e.message); }
}
async function doLogin(){
  $('gate-err').style.display='none';
  const { data, error } = await SB.auth.signInWithPassword({
    email: $('li-email').value.trim(), password: $('li-pass').value
  });
  if (error) return gateErr(error.message);
  SESSION = data.session;
  await enter();
}
async function doSignup(){
  $('gate-err').style.display='none';
  try{
    await api('/api/auth', {
      action:'signup',
      inviteCode: $('su-invite').value.trim(),
      email: $('su-email').value.trim(),
      password: $('su-pass').value,
      fullName: $('su-name').value.trim()
    });
    const { data, error } = await SB.auth.signInWithPassword({
      email: $('su-email').value.trim(), password: $('su-pass').value
    });
    if (error) return gateErr(error.message);
    SESSION = data.session;
    await enter();
  }catch(e){ gateErr(e.message); }
}
async function enter(){
  try{
    const { profile } = await api('/api/auth', {action:'me'});
    ME = profile;
    $('nav').style.display='flex';
    $('who').textContent = (ME.full_name || ME.email) + (ME.role==='manager' ? ' · manager' : '');
    $('who').style.display='inline';
    // Pre-fill the AE identity fields on the form
    if ($('f-ae') && !$('f-ae').value) $('f-ae').value = ME.full_name || '';
    if ($('f-email') && !$('f-email').value) $('f-email').value = ME.email || '';
    show('new');
    // Surface waiting-question count on the badge right away
    api('/api/questions', {action:'inbox'}).then(d=>{
      updateInboxBadge((d.questions||[]).filter(q=>q.status!=='answered').length);
    }).catch(()=>{});
    // Reveal the "Import from Gong" button if the integration is configured
    checkGongStatus();
  }catch(e){ gateErr('Signed in, but profile lookup failed: '+e.message); }
}
async function logout(){
  await SB.auth.signOut();
  location.reload();
}
document.addEventListener('DOMContentLoaded', initAuth);
