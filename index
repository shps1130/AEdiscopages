async function pickGongCall(callId, title){
  $('gong-list').innerHTML = `<div style="padding:32px;text-align:center;color:var(--navy-70);font-family:JetBrains Mono,monospace;font-size:.78rem">Fetching transcript for ${esc(title)}…</div>`;
