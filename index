async function readCall(){
  const transcript = $('f-transcript').value.trim();
  if(transcript.length < 200){ toast('Paste a real transcript first'); return; }
  $('btn-read').disabled = true;
  $('extraction-status').style.display='block';
  $('extraction-status').textContent = '▸ Reading the call…';
  try{
    const data = await api('/api/extract', { transcript });
    const f = data.form || {};
    $('f-org').value = f.orgName || '';
    if(f.vertical) $('f-vertical').value = f.vertical;
    $('f-tool').value = f.incumbentTool || '';
    $('f-fye').value = f.fiscalYearEnd || '';
    $('f-notes').value = f.aeNotes || '';
    // Meeting link isn't in the transcript — default to your last one for convenience
    if(!$('f-meeting-link').value && localStorage.getItem('fw_last_meeting_link')){
      $('f-meeting-link').value = localStorage.getItem('fw_last_meeting_link');
    }
    // Mark which fields the extraction actually filled with a coral dot
    document.querySelectorAll('.field-mark').forEach(el=>el.classList.remove('filled'));
    (data.extractedFields||[]).forEach(name=>{
      const el = document.querySelector(`.field-mark[data-field="${name}"]`);
      if(el) el.classList.add('filled');
    });
    const n = (data.extractedFields||[]).length;
    $('extraction-status').innerHTML = `✓ Filled in <b>${n}</b> field${n===1?'':'s'} from the call. Review below, add anything missing, then generate.`;
    $('form-block').style.display='block';
    $('form-block').scrollIntoView({behavior:'smooth', block:'start'});
  }catch(e){
    $('extraction-status').textContent = 'Reading failed: '+e.message;
    // Still show the form so the AE can fill it manually
    $('form-block').style.display='block';
  }finally{
    $('btn-read').disabled = false;
  }
}

async function generate(){
  const form = {
    orgName: $('f-org').value.trim(),
    vertical: $('f-vertical').value,
    aeName: $('f-ae').value.trim(),
    aeEmail: $('f-email').value.trim(),
    incumbentTool: $('f-tool').value.trim(),
    fiscalYearEnd: $('f-fye').value.trim(),
    meetingLink: $('f-meeting-link').value.trim(),
    notifyEmail: $('f-notify').value.trim(),
    gongCallUrl: $('f-gong-url').value.trim(),
    aeNotes: $('f-notes').value.trim()
  };
  const transcript = $('f-transcript').value.trim();
  $('new-err').style.display='none';
  if(!form.orgName || transcript.length < 200){
    $('new-err').textContent='Need an organization name (the form below) and a real transcript.';
    $('new-err').style.display='block'; return;
  }
  // Remember scheduling link across cases so it's pre-filled next time
  if(form.meetingLink) localStorage.setItem('fw_last_meeting_link', form.meetingLink);
  $('btn-generate').disabled = true;
  $('working').style.display='block';
  ['s1','s2','s3','s4'].forEach(s=>$(s).className='step');
  $('s1').classList.add('on');
  // The API does all steps in one call; walk the UI on a timer that roughly matches reality.
  const t1=setTimeout(()=>{$('s1').className='step done';$('s2').classList.add('on');}, 12000);
  const t2=setTimeout(()=>{$('s2').className='step done';$('s3').classList.add('on');}, 16000);
  try{
    const data = await api('/api/generate', { form, transcript });
    [t1,t2].forEach(clearTimeout);
    ['s1','s2','s3'].forEach(s=>$(s).className='step done');
    $('s4').className='step done';
    CURRENT = { pageId:data.pageId, html:data.html, brief:data.brief, slug:null, status:'draft', schedule:data.schedule||[], gongCallUrl:$('f-gong-url').value.trim() };
    renderBrief(data.brief, data.assetsUsed, $('f-org').value.trim());
    renderPreview();
    renderSchedule();
    if($('notify-email')) $('notify-email').value = $('f-notify').value.trim();
    $('urlbar').style.display='none';
    $('activity-bar').style.display='none';
    $('btn-publish').textContent='Publish…';
    show('case');
    toast('Draft ready — review the brief before publishing');
  }catch(e){
    [t1,t2].forEach(clearTimeout);
    $('new-err').textContent = 'Generation failed: '+e.message;
    $('new-err').style.display='block';
  }finally{
    $('btn-generate').disabled=false;
    $('working').style.display='none';
  }
}

