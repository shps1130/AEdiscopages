        <div class="mono" style="font-size:.72rem;color:var(--navy-70);margin-bottom:10px">Asked by ${q.asker_name?esc(q.asker_name):'someone (anonymous)'}</div>
        ${q.status==='answered'
          ? `<div style="background:var(--navy);color:var(--cream);border-radius:8px;padding:10px 12px;font-size:.88rem">${esc(q.answer)}</div><div class="mono" style="font-size:.66rem;color:var(--navy-70);margin-top:5px">Answered by ${esc(q.answered_by||'')}</div>`
          : `<textarea id="ans-${q.id}" placeholder="Write your answer…" style="width:100%;min-height:70px;border:1px solid var(--navy-15);border-radius:8px;padding:10px;font:inherit"></textarea>
             <button class="btn small" style="margin-top:8px" onclick="answerQ('${q.id}')">Send answer</button>`}
      </div>`;
    box.innerHTML =
      (open.length ? `<h2 style="font-family:'Fraunces',serif;font-size:1.1rem;margin:0 0 14px">Waiting for you (${open.length})</h2>` + open.map(render).join('') : `<p style="color:var(--navy-70)">No open questions. Nice.</p>`) +
