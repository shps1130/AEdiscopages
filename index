             onmouseover="this.style.background='rgba(20,34,58,.06)'" onmouseout="this.style.background='transparent'">
          <div style="font-family:'Fraunces',serif;font-size:1rem;color:var(--navy);margin-bottom:2px">${esc(c.title)}</div>
