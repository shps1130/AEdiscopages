<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>FreeWill Prospect Pages</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#14223A; --cream:#F4ECE0; --coral:#E04F3E;
    --navy-70:rgba(20,34,58,.7); --navy-15:rgba(20,34,58,.15); --navy-08:rgba(20,34,58,.08);
    --ok:#2E7D4F;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--cream);color:var(--navy);font-family:'Inter Tight',sans-serif;font-size:16px;line-height:1.55;min-height:100vh}
  .mono{font-family:'JetBrains Mono',monospace}
  .display{font-family:'Fraunces',serif}

  header{display:flex;align-items:baseline;justify-content:space-between;padding:20px 32px;border-bottom:1px solid var(--navy-15)}
  header .wordmark{font-family:'Fraunces',serif;font-weight:700;font-size:1.15rem}
  header .wordmark span{color:var(--coral)}
  nav{display:flex;gap:4px}
  nav button{background:none;border:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;color:var(--navy-70);padding:8px 14px;border-radius:99px}
  nav button.active{background:var(--navy);color:var(--cream)}

  main{max-width:1200px;margin:0 auto;padding:36px 32px 80px}
  .eyebrow{font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--coral);margin-bottom:10px}
  h1{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(1.7rem,3.4vw,2.5rem);line-height:1.12;margin-bottom:10px}
  .lede{color:var(--navy-70);max-width:56ch;margin-bottom:32px}

  /* ---------- forms ---------- */
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .grid .full{grid-column:1/-1}
  label{display:block;font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--navy-70);margin-bottom:6px}
  input,select,textarea{width:100%;background:#fff;border:1px solid var(--navy-15);border-radius:8px;padding:11px 13px;font:inherit;color:var(--navy)}
  input:focus,select:focus,textarea:focus{outline:2px solid var(--coral);outline-offset:1px;border-color:transparent}
  textarea{resize:vertical}
  .hint{font-size:.8rem;color:var(--navy-70);margin-top:5px}
  .field-mark{display:inline-block;width:8px;height:8px;border-radius:50%;background:transparent;vertical-align:middle;margin-left:6px;transition:background .2s, box-shadow .2s}
  .field-mark.filled{background:var(--coral);box-shadow:0 0 0 3px rgba(224,79,62,.15)}

  .btn{display:inline-flex;align-items:center;gap:8px;background:var(--coral);color:#fff;border:none;border-radius:99px;padding:13px 26px;font-family:'JetBrains Mono',monospace;font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer}
  .btn:hover{filter:brightness(1.06)}
  .btn:disabled{opacity:.5;cursor:default}
  .btn.ghost{background:none;color:var(--navy);border:1px solid var(--navy-15)}
  .btn.navy{background:var(--navy)}
  .btn.small{padding:8px 16px;font-size:.68rem}

  /* ---------- the working state ---------- */
  .working{display:none;margin-top:28px;border-top:2px solid var(--navy);padding-top:20px}
  .working .step{display:flex;gap:12px;align-items:baseline;font-family:'JetBrains Mono',monospace;font-size:.78rem;padding:6px 0;color:var(--navy-70)}
  .working .step.on{color:var(--navy)}
  .working .step.on::before{content:'▸';color:var(--coral)}
  .working .step.done::before{content:'✓';color:var(--ok)}
  .working .step::before{content:'·';width:14px;display:inline-block}

  /* ---------- case view: brief + preview ---------- */
  .case{display:none;grid-template-columns:400px 1fr;gap:28px;align-items:start}
  @media(max-width:960px){.case{grid-template-columns:1fr}}
  .brief{background:var(--navy);color:var(--cream);border-radius:14px;padding:26px;position:sticky;top:20px;max-height:calc(100vh - 40px);overflow-y:auto}
  .brief h2{font-family:'Fraunces',serif;font-size:1.3rem;margin-bottom:4px}
  .brief .sub{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;opacity:.6;margin-bottom:18px}
  .brief section{margin-bottom:18px}
  .brief h3{font-family:'JetBrains Mono',monospace;font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;color:var(--coral);margin-bottom:8px}
  .brief ul{list-style:none}
  .brief li{font-size:.86rem;padding:6px 0;border-bottom:1px solid rgba(244,236,224,.12)}
  .brief li b{font-weight:600}
  .brief li .ev{display:block;opacity:.65;font-size:.78rem;margin-top:2px}
  .brief .chip{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:.66rem;background:rgba(244,236,224,.12);border-radius:99px;padding:3px 10px;margin:0 6px 6px 0}
  .brief .risk{background:rgba(224,79,62,.18);border-left:3px solid var(--coral);padding:8px 10px;border-radius:0 6px 6px 0;font-size:.82rem;margin-bottom:8px}

  .stage{background:#fff;border:1px solid var(--navy-15);border-radius:14px;overflow:hidden}
  .stage .bar{display:flex;align-items:center;gap:10px;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--navy-15);flex-wrap:wrap}
  .stage .bar .actions{display:flex;gap:8px;flex-wrap:wrap}
  .stage iframe{width:100%;height:72vh;border:none;display:block;background:#fff}
  .stage textarea.htmledit{height:72vh;border:none;border-radius:0;font-family:'JetBrains Mono',monospace;font-size:.78rem;display:none}

  .revisebox{display:none;padding:14px 16px;border-top:1px solid var(--navy-15);background:var(--cream)}
  .revisebox textarea{height:80px}
  .revisebox .row{display:flex;gap:10px;margin-top:10px;align-items:center}

  .schedbox{grid-column:1/-1;background:#fff;border:1px solid var(--navy-15);border-radius:14px;overflow:hidden;margin-top:20px;clear:both;position:relative;z-index:1}
  .schedbox .bar{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;border-bottom:1px solid var(--navy-15)}
  .sched-step{padding:14px 16px;border-bottom:1px solid var(--navy-08);display:grid;grid-template-columns:1.2fr .7fr 1fr;gap:14px;align-items:start}
  @media(max-width:800px){.sched-step{grid-template-columns:1fr}}
  .sched-step .pending{background:rgba(224,79,62,.1);border-left:3px solid var(--coral);padding:6px 10px;border-radius:0 6px 6px 0;font-size:.78rem;margin-bottom:8px}
  .sched-step .q{background:var(--navy-08);border-radius:8px;padding:8px 10px;font-size:.82rem;margin-bottom:6px}
  .sched-step .q textarea{margin-top:6px;height:50px;font-size:.82rem}
  .sched-accept{background:none;border:1px solid var(--coral);color:var(--coral);border-radius:99px;padding:4px 10px;font-family:'JetBrains Mono',monospace;font-size:.64rem;cursor:pointer;margin-left:8px}

  /* ---------- pages list ---------- */
  table{width:100%;border-collapse:collapse;background:#fff;border-radius:14px;overflow:hidden;border:1px solid var(--navy-15)}
  th{font-family:'JetBrains Mono',monospace;font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;text-align:left;color:var(--navy-70);padding:12px 16px;border-bottom:2px solid var(--navy)}
  td{padding:13px 16px;border-bottom:1px solid var(--navy-08);font-size:.9rem}
  tr:hover td{background:var(--navy-08);cursor:pointer}
  .pill{font-family:'JetBrains Mono',monospace;font-size:.64rem;letter-spacing:.06em;text-transform:uppercase;border-radius:99px;padding:3px 10px}
  .pill.draft{background:var(--navy-08);color:var(--navy)}
  .pill.published{background:var(--ok);color:#fff}
  .views{font-family:'JetBrains Mono',monospace;font-size:.8rem}

  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--navy);color:var(--cream);font-family:'JetBrains Mono',monospace;font-size:.75rem;padding:12px 22px;border-radius:99px;opacity:0;transition:opacity .25s;pointer-events:none;max-width:90vw}
  .toast.show{opacity:1}
  .err{color:var(--coral);font-size:.85rem;margin-top:10px;display:none}

  /* ---------- access gate ---------- */
  .gate{max-width:380px;margin:12vh auto;text-align:center}
  .gate input{text-align:center;font-family:'JetBrains Mono',monospace;letter-spacing:.2em;margin:18px 0 12px}
  .view{display:none}.view.on{display:block}
  .case.on{display:grid}
</style>
</head>
<body>

<header>
  <div class="wordmark">FreeWill <span>/</span> Prospect Pages</div>
  <nav id="nav" style="display:none;align-items:center">
    <span id="who" class="mono" style="display:none;font-size:.68rem;color:var(--navy-70);margin-right:8px"></span>
    <button data-view="new" class="active">New case</button>
    <button data-view="list">All pages</button>
    <button data-view="inbox">Questions <span id="inbox-badge" class="mono" style="display:none;background:var(--coral);color:#fff;border-radius:99px;padding:1px 7px;font-size:.62rem;margin-left:2px"></span></button>
    <button onclick="location.href='/admin.html'" type="button">Knowledge base ↗</button>
    <button onclick="logout()" type="button">Sign out</button>
  </nav>
</header>

<main>
  <!-- ================= GATE ================= -->
  <div class="view gate on" id="view-gate">
    <div class="eyebrow">Internal tool</div>
    <h1 class="display" id="gate-title">Sign in</h1>
    <div id="gate-login">
      <input id="li-email" type="email" placeholder="you@freewill.com" autocomplete="email" style="letter-spacing:0;text-align:left">
      <input id="li-pass" type="password" placeholder="password" autocomplete="current-password" style="letter-spacing:0;text-align:left;margin-top:0">
      <br><button class="btn" onclick="doLogin()">Sign in</button>
      <p class="hint" style="margin-top:14px">First time? <a href="#" onclick="gateMode('signup');return false">Create your account</a></p>
    </div>
    <div id="gate-signup" style="display:none">
      <input id="su-name" placeholder="Full name" style="letter-spacing:0;text-align:left">
      <input id="su-email" type="email" placeholder="you@freewill.com" style="letter-spacing:0;text-align:left;margin-top:0">
      <input id="su-pass" type="password" placeholder="password (8+ characters)" style="letter-spacing:0;text-align:left;margin-top:0">
      <input id="su-invite" type="password" placeholder="team invite code" style="margin-top:0">
      <br><button class="btn" onclick="doSignup()">Create account</button>
      <p class="hint" style="margin-top:14px"><a href="#" onclick="gateMode('login');return false">Back to sign in</a></p>
    </div>
    <div class="err" id="gate-err"></div>
  </div>

  <!-- ================= NEW CASE ================= -->
  <div class="view" id="view-new">
    <div class="eyebrow">New case</div>
    <h1>Paste the call. We'll do the reading.</h1>
    <p class="lede">Drop the transcript. Hit read. The form fills itself in with what the call revealed — you review, add what wasn't discussed, and generate.</p>

    <label>Call transcript (paste from Gong)</label>
    <textarea id="f-transcript" rows="10" placeholder="Paste the full transcript…" style="font-family:'JetBrains Mono',monospace;font-size:.85rem"></textarea>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;flex-wrap:wrap;gap:10px">
      <div class="hint" id="t-count">0 words</div>
      <div style="display:flex;gap:8px">
        <button class="btn ghost small" id="btn-gong" onclick="openGongPicker()" style="display:none">↗ Import from Gong</button>
        <button class="btn" id="btn-read" onclick="readCall()" style="background:var(--navy)" disabled>Read the call</button>
      </div>
    </div>
    <div style="margin-top:14px">
      <label>Gong call link <span class="hint" style="font-family:'Inter Tight',sans-serif;font-size:.72rem;font-weight:normal;text-transform:none;letter-spacing:0;color:var(--navy-70);margin-left:6px">optional · lets you jump back to the source call from the case</span></label>
      <input id="f-gong-url" type="url" placeholder="https://us-XXXXX.app.gong.io/call?id=…">
    </div>

    <div id="extraction-status" style="display:none;margin-top:18px;padding:14px 18px;background:var(--navy);color:var(--cream);border-radius:12px;font-family:'JetBrains Mono',monospace;font-size:.78rem"></div>

    <div id="form-block" style="display:none;margin-top:28px">
      <div class="eyebrow" style="color:var(--navy-70)">Review &amp; complete</div>
      <p class="lede" style="margin-bottom:20px">Fields with a coral dot were pulled from the call. Fix anything wrong, fill anything missing.</p>
      <div class="grid">
        <div><label>Organization name <span class="field-mark" data-field="orgName"></span></label><input id="f-org" placeholder="Jesuit High School Portland"></div>
        <div><label>Vertical <span class="field-mark" data-field="vertical"></span></label>
          <select id="f-vertical">
            <option value="catholic">Catholic parish / diocese</option>
            <option value="evangelical">Evangelical church</option>
            <option value="mainline">Mainline church</option>
            <option value="k12">K-12 school</option>
            <option value="higher-ed">Higher education</option>
            <option value="rescue-mission">Rescue mission</option>
            <option value="media-ministry">Media ministry</option>
            <option value="other">Other nonprofit</option>
          </select>
        </div>
        <div><label>Incumbent PG tool, if any <span class="field-mark" data-field="incumbentTool"></span></label><input id="f-tool" placeholder="PG Calc, Crescendo, none…"></div>
        <div><label>Fiscal year end <span class="field-mark" data-field="fiscalYearEnd"></span></label><input id="f-fye" placeholder="June 30"></div>
        <div><label>Your scheduling link</label><input id="f-meeting-link" placeholder="https://calendly.com/tim-freewill"></div>
        <div><label>Notify this address when a prospect asks a question</label><input id="f-notify" type="email" placeholder="dev.director@theirorg.com"></div>
        <div class="full"><label>Anything else worth knowing <span class="field-mark" data-field="aeNotes"></span></label><input id="f-notes" placeholder="Champion is the board chair; sensitive about a failed 2023 campaign…"></div>
        <!-- Your identity, pre-filled from your profile — stays hidden since it never changes per-case -->
        <input id="f-ae" type="hidden">
        <input id="f-email" type="hidden">
      </div>
      <div style="margin-top:24px"><button class="btn" id="btn-generate" onclick="generate()">Generate draft page</button></div>
      <div class="err" id="new-err"></div>

      <div class="working" id="working">
        <div class="step" id="s1">Reading the transcript &amp; building the prospect brief</div>
        <div class="step" id="s2">Matching FreeWill case studies &amp; materials</div>
        <div class="step" id="s3">Writing the page (this is the long one — ~60–90s)</div>
        <div class="step" id="s4">Saving draft</div>
      </div>
    </div>
  </div>

  <!-- ================= CASE (brief + preview) ================= -->
  <div class="case" id="view-case">
    <aside class="brief" id="brief"><!-- filled by JS --></aside>
    <div class="stage">
      <div class="bar">
        <span class="mono" style="font-size:.72rem;letter-spacing:.08em;text-transform:uppercase" id="stage-title">Draft preview</span>
        <div class="actions">
          <button class="btn ghost small" onclick="toggleEdit()" id="btn-edit">Edit HTML</button>
          <button class="btn ghost small" onclick="toggleRevise()">Revise with AI</button>
          <button class="btn navy small" onclick="openFull()">Open full size</button>
          <button class="btn small" onclick="publishPrompt()" id="btn-publish">Publish…</button>
        </div>
      </div>
      <div id="activity-bar" style="display:none;padding:10px 16px;background:var(--cream);border-bottom:1px solid var(--navy-15);font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.04em;color:var(--navy)">
        <span class="mono" style="font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--coral);margin-right:10px">Activity</span>
        <span id="activity-summary">—</span>
      </div>
      <div id="urlbar" style="display:none;align-items:center;gap:10px;padding:12px 16px;background:var(--navy);border-bottom:1px solid var(--navy-15);flex-wrap:wrap">
        <span class="mono" style="font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--coral)">Live URL</span>
        <a id="urlbar-link" href="#" target="_blank" rel="noopener" style="flex:1;min-width:220px;color:var(--cream);font-family:'JetBrains Mono',monospace;font-size:.82rem;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></a>
        <button class="btn small" onclick="copyUrl()" id="btn-copy">Copy link</button>
        <button class="btn ghost small" onclick="openLive()" style="color:var(--cream);border-color:rgba(244,236,224,.3)">Open ↗</button>
      </div>
      <iframe id="preview" sandbox="allow-scripts allow-same-origin"></iframe>
      <textarea class="htmledit" id="htmledit" spellcheck="false"></textarea>
      <div class="revisebox" id="revisebox">
        <label>What should change?</label>
        <textarea id="revise-text" placeholder="Soften the IT tab, lead the FAQ with the board-approval question, and mention their June 30 fiscal year in Path Forward."></textarea>
        <div class="row">
          <button class="btn small" onclick="revise()" id="btn-revise">Apply revision</button>
          <span class="mono" style="font-size:.72rem;color:var(--navy-70)" id="revise-status"></span>
        </div>
      </div>
    </div>
    <div class="schedbox" id="schedbox">
      <div class="bar"><span class="mono" style="font-size:.72rem;letter-spacing:.08em;text-transform:uppercase">Path Forward schedule</span>
        <button class="btn small" onclick="saveSchedule()">Save schedule</button></div>
      <div style="padding:12px 16px;border-bottom:1px solid var(--navy-08);display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <label style="margin:0">Question notifications go to:</label>
        <input id="notify-email" type="email" placeholder="dev.director@theirorg.com" style="flex:1;min-width:200px">
        <button class="btn ghost small" onclick="saveNotify()">Save</button>
      </div>
      <div id="sched-list"></div>
    </div>
  </div>

  <!-- ================= LIST ================= -->
  <div class="view" id="view-list">
    <div class="eyebrow">All pages</div>
    <h1>The board.</h1>
    <p class="lede">Every draft and live page across the team. Views count real prospect opens — a page opened four times means someone's forwarding it.</p>
    <table>
      <thead><tr><th>Organization</th><th>Status</th><th>Owner</th><th>Opens</th><th>Last opened</th><th>Updated</th></tr></thead>
      <tbody id="pages-body"><tr><td colspan="6" style="color:var(--navy-70)">Loading…</td></tr></tbody>
    </table>
  </div>

  <!-- ================= INBOX ================= -->
  <div class="view" id="view-inbox">
    <div class="eyebrow">Questions</div>
    <h1>What prospects are asking.</h1>
    <p class="lede">Every question from your pages lands here. You answer in your own words — no bot speaks for you. When you answer, the prospect gets an email the moment it's done.</p>
    <div id="inbox-list"><p style="color:var(--navy-70)">Loading…</p></div>
  </div>
  <!-- ================= GONG PICKER MODAL ================= -->
  <div id="gong-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(20,34,58,.5);align-items:center;justify-content:center;padding:20px">
    <div style="background:var(--cream);border-radius:16px;max-width:640px;width:100%;max-height:88vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(20,34,58,.4)">
      <div style="padding:22px 26px;border-bottom:1px solid var(--navy-15);display:flex;justify-content:space-between;align-items:baseline">
        <div>
          <div class="eyebrow" style="margin-bottom:4px">Import from Gong</div>
          <div style="font-family:'Fraunces',serif;font-size:1.25rem">Your recent calls</div>
        </div>
        <button onclick="closeGongPicker()" style="background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--navy-70);line-height:1">×</button>
      </div>
      <div id="gong-list" style="overflow-y:auto;flex:1;padding:6px 8px">
        <div style="padding:32px;text-align:center;color:var(--navy-70);font-family:'JetBrains Mono',monospace;font-size:.78rem">Loading calls…</div>
      </div>
    </div>
  </div>
</main>

<div class="toast" id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script>
const $ = id => document.getElementById(id);
let SB = null;            // supabase client, created after /api/auth config fetch
let SESSION = null;       // supabase session (holds access_token)
let ME = null;            // my profile {id, email, full_name, role}
let CURRENT = { pageId:null, html:'', brief:null, slug:null, status:'draft', schedule:[], readOnly:false };

/* ---------- plumbing ---------- */
function toast(msg){ const t=$('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'), 3200); }
async function api(path, body){
  const headers = {'content-type':'application/json'};
  if (SESSION?.access_token) headers['authorization'] = 'Bearer ' + SESSION.access_token;
  const r = await fetch(path, {method:'POST', headers, body:JSON.stringify(body||{})});
  const data = await r.json().catch(()=>({error:'Bad response'}));
  if(!r.ok) throw new Error(data.error || r.status);
  return data;
}
function show(view){
  document.querySelectorAll('.view,.case').forEach(v=>v.classList.remove('on'));
  $('view-'+view).classList.add('on');
  document.querySelectorAll('nav button[data-view]').forEach(b=>b.classList.toggle('active', b.dataset.view===view));
  if(view==='list') loadPages();
  if(view==='inbox') loadInbox();
}
document.querySelectorAll('nav button[data-view]').forEach(b=>b.onclick=()=>show(b.dataset.view));

/* ---------- inbox (Q&A) ---------- */
async function loadInbox(){
  try{
    const {questions} = await api('/api/questions', {action:'inbox'});
    const open = questions.filter(q=>q.status!=='answered');
    const answered = questions.filter(q=>q.status==='answered');
    const box = $('inbox-list');
    const render = q => `
      <div style="background:#fff;border:1px solid var(--navy-15);border-radius:12px;padding:16px 18px;margin-bottom:12px">
        <div class="mono" style="font-size:.64rem;letter-spacing:.08em;text-transform:uppercase;color:var(--coral);margin-bottom:4px">${esc(q.org_name||'')} · ${esc(q.section||'general')} · ${new Date(q.created_at).toLocaleDateString()}</div>
