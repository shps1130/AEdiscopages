/* ---------- Gong picker ---------- */
// Show the Gong button if the integration is wired up on the server side.
// Runs once at sign-in from enter().
async function checkGongStatus(){
  try{
    const d = await api('/api/gong', { action:'status' });
    if(d.configured) $('btn-gong').style.display='inline-flex';
  }catch(e){ /* silent — Gong is optional */ }
}
function closeGongPicker(){ $('gong-modal').style.display='none'; }
async function openGongPicker(){
  $('gong-modal').style.display='flex';
  $('gong-list').innerHTML = '<div style="padding:32px;text-align:center;color:var(--navy-70);font-family:JetBrains Mono,monospace;font-size:.78rem">Loading your recent calls…</div>';
  try{
    const d = await api('/api/gong', { action:'listMine', daysBack:30 });
