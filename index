// Human-friendly relative time: "2h ago", "3d ago", "just now", etc.
function relativeTime(iso){
  if(!iso) return '';
  const then = new Date(iso).getTime();
  const s = Math.max(0, Math.floor((Date.now() - then) / 1000));
  if(s < 60) return 'just now';
  if(s < 3600) return Math.floor(s/60) + 'm ago';
  if(s < 86400) return Math.floor(s/3600) + 'h ago';
  if(s < 604800) return Math.floor(s/86400) + 'd ago';
  return new Date(iso).toLocaleDateString();
}
async function loadPages(){
  try{
    const data = await api('/api/pages',{action:'list'});
    const isMgr = data.role === 'manager';
    document.querySelector('#view-list .lede').textContent = isMgr
      ? "Every deal across the team. Coral dot means new activity since you last checked. You can open any page read-only; owners keep editing rights."
      : "Your drafts and live pages. Coral dot means the prospect opened it since you last checked — worth a light follow-up.";
    // What was the newest last_opened_at last time this AE viewed the board?
    // Anything opened after that gets a coral "new activity" dot.
    const seenKey = 'fw_board_seen_at';
    const lastSeen = parseInt(localStorage.getItem(seenKey) || '0', 10);
    let newestOpen = lastSeen;
    $('pages-body').innerHTML = data.pages.map(p=>{
      const openedTs = p.last_opened_at ? new Date(p.last_opened_at).getTime() : 0;
      const isNew = openedTs > lastSeen;
      if(openedTs > newestOpen) newestOpen = openedTs;
      const dot = isNew
        ? '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--coral);margin-right:8px;vertical-align:middle" title="New activity since your last visit"></span>'
        : '<span style="display:inline-block;width:8px;margin-right:8px"></span>';
      return `
      <tr onclick="openPage('${p.id}')">
        <td>${dot}<b>${esc(p.org_name)}</b>${p.slug?`<span class="mono" style="font-size:.72rem;color:var(--navy-70)"> /p/${esc(p.slug)}</span>`:''}</td>
        <td><span class="pill ${p.status}">${p.status}</span></td>
        <td>${esc(p.owner_name||p.created_by||'')}</td>
        <td class="views">${p.view_count || 0} ${(p.view_count||0)===1?'open':'opens'}</td>
        <td class="mono" style="font-size:.75rem;color:${isNew?'var(--coral)':'var(--navy-70)'}">${p.last_opened_at?relativeTime(p.last_opened_at):'—'}</td>
        <td class="mono" style="font-size:.75rem">${new Date(p.updated_at).toLocaleDateString()}</td>
      </tr>`;
    }).join('') || '<tr><td colspan="6" style="color:var(--navy-70)">No pages yet — start a new case.</td></tr>';
    // Mark the board as seen (so next time only NEWER opens light up).
    if(newestOpen) localStorage.setItem(seenKey, String(newestOpen));
  }catch(e){ $('pages-body').innerHTML = `<tr><td colspan="6">Failed to load: ${esc(e.message)}</td></tr>`; }
}
async function openPage(id){
  try{
    const {page, readOnly} = await api('/api/pages',{action:'get',pageId:id});
    CURRENT = { pageId:page.id, html:page.html, brief:page.brief, slug:page.slug, status:page.status, schedule:page.schedule||[], readOnly:!!readOnly, gongCallUrl:page.gong_call_url || page.form_inputs?.gongCallUrl || '' };
    renderBrief(page.brief||{}, (page.brief?._assets)||[], page.org_name);
    renderPreview();
    renderSchedule();
    if($('notify-email')) $('notify-email').value = page.notify_email || '';
    // Managers viewing someone else's deal get a read-only stage
    document.querySelectorAll('.stage .actions button, #schedbox .bar button').forEach(b=>{
      b.style.display = CURRENT.readOnly && b.textContent !== 'Open full size' ? 'none' : '';
    });
    $('stage-title').textContent = (CURRENT.readOnly ? 'Read-only · ' : '') + (page.status==='published' ? 'Live: /p/'+page.slug : 'Draft preview');
    $('btn-publish').textContent = page.status==='published' ? 'Update URL…' : 'Publish…';
    showUrlBar();
    showActivityBar(page);
    show('case');
  }catch(e){ toast('Could not open: '+e.message); }
}
</script>
